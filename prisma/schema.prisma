generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- Enums ---

enum UserRole {
  PATIENT
  DOCTOR
  PHARMACY
  PHARMACIST
  LAB_SCIENTIST
  DIETITIAN
  ADMIN
  SUPER_ADMIN
}

enum ProfessionalStatus {
  VERIFIED
  PENDING
  SUSPENDED
}

enum RegBody {
  MDCN
  PCN
  MLSCN
  ODBN
}

enum Vertical {
  ED
  WEIGHT_LOSS
}

enum AccountStatus {
  PENDING_INTAKE
  PENDING_CONSULT
  ACTIVE
  PAUSED
  SUSPENDED
  CANCELLED
  INELIGIBLE
}

enum EligibilityResult {
  ELIGIBLE
  EXCLUDED
  PENDING
}

enum PrescriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum OrderStatus {
  PENDING
  ACKNOWLEDGED
  PACKED
  DISPATCHED
  DELIVERED
  FAILED
}

enum LogisticsPartner {
  GIG
  KWIK
  SENDBOX
  OTHER
}

enum PlanCode {
  ED_BASIC
  ED_STANDARD
  ED_PREMIUM
  WL_STARTER
  WL_CORE
  WL_VIP
}

enum ConsultMode {
  ASYNC
  VIDEO
}

enum LabRequestStatus {
  PENDING
  SAMPLE_COLLECTED
  PROCESSING
  COMPLETED
  CANCELLED
}

enum ResultFlag {
  NORMAL
  ABNORMAL
  CRITICAL
}

enum DietPlanStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum TreatmentPlanStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum ConsultNoteType {
  SOAP
  FOLLOW_UP
  INITIAL
}

enum MessageThread {
  PATIENT_DOCTOR
  PATIENT_DIETITIAN
  SYSTEM_ANNOUNCEMENT
}

enum SampleMethod {
  HOME_COLLECTION
  WALK_IN
}

// --- Auth & Users ---

model User {
  id                       String               @id @default(uuid())
  email                    String               @unique
  phone                    String?
  password                 String
  role                     UserRole             @default(PATIENT)
  isActive                 Boolean              @default(true)
  isEmailVerified          Boolean              @default(false)
  emailVerificationToken   String?              @unique
  emailVerificationExpires DateTime?
  passwordResetToken       String?              @unique
  passwordResetExpires     DateTime?
  failedLoginAttempts      Int                  @default(0)
  lockUntil                DateTime?
  mfaSecret                String?
  mfaEnabled               Boolean              @default(false)
  createdAt                DateTime             @default(now())
  lastLoginAt              DateTime?
  refreshTokens            RefreshToken[]
  patient                  Patient?
  professionalProfile      ProfessionalProfile?
  auditLogs                AuditLog[]

  @@index([email])
  @@index([role])
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  userAgent String?
  ipAddress String?
  user      User      @relation(fields: [userId], references: [id])

  @@index([userId])
}

// --- Clinical Entities ---

model Patient {
  id                String               @id @default(uuid())
  userId            String               @unique
  firstName         String
  lastName          String
  gender            String
  dob               DateTime
  address           String
  stateOfResidence  String
  ndprConsentAt     DateTime?
  marketingOptIn    Boolean              @default(false)
  accountStatus     AccountStatus        @default(PENDING_INTAKE)
  user              User                 @relation(fields: [userId], references: [id])
  subscriptions     Subscription[]
  intakes           Intake[]
  prescriptions     Prescription[]
  orders            Order[]
  treatmentPlans    TreatmentPlan[]
  labRequests       LabTestRequest[]
  dietPlans         DietPlan[]
  progressEntries   ProgressEntry[]
  professionals     PatientProfessional[]
  messages          Message[]
  consultationNotes ConsultationNote[]

  @@index([accountStatus])
}

model ProfessionalProfile {
  id               String             @id @default(uuid())
  userId           String             @unique
  fullName         String
  registrationNum  String             @unique // MDCN/PCN/MLSCN number
  regBody          RegBody
  specialisation   String?
  status           ProfessionalStatus @default(PENDING)
  isAvailable      Boolean            @default(true)
  availability     String? // JSON
  maxOpenConsults  Int                @default(25)
  user             User               @relation(fields: [userId], references: [id])
  patients         PatientProfessional[]
  prescriptions    Prescription[]
  intakeReviews    Intake[]
  treatmentPlans   TreatmentPlan[]
  labRequests      LabTestRequest[]
  dietPlans        DietPlan[]
  consultationNotes ConsultationNote[]
  videoSlots       VideoSlot[]
  progressAnnotated ProgressEntry[]

  @@index([status])
  @@index([regBody])
}

model PatientProfessional {
  patientId      String
  professionalId String
  assignedAt     DateTime            @default(now())
  patient        Patient             @relation(fields: [patientId], references: [id])
  professional   ProfessionalProfile @relation(fields: [professionalId], references: [id])

  @@id([patientId, professionalId])
}

model Pharmacy {
  id          String   @id @default(uuid())
  name        String
  pcnLicence  String   @unique
  address     String?
  canCompound Boolean  @default(false)
  cities      String // JSON
  isActive    Boolean  @default(true)
  orders      Order[]
}

// --- Care & Treatment ---

model Subscription {
  id              String         @id @default(uuid())
  patientId       String
  vertical        Vertical
  planCode        PlanCode
  status          AccountStatus
  paystackCode    String?        @unique
  amount          Int
  billingDay      Int
  nextBillingDate DateTime?
  createdAt       DateTime       @default(now())
  patient         Patient        @relation(fields: [patientId], references: [id])
  intakes         Intake[]
  prescriptions   Prescription[]
  orders          Order[]
  paymentEvents   PaymentEvent[]

  @@index([patientId, status])
}

model Intake {
  id             String            @id @default(uuid())
  patientId      String
  subscriptionId String?
  vertical       Vertical
  responsesEnc   String
  clinicalFlags  String?
  eligibility    EligibilityResult @default(PENDING)
  status         String            @default("draft")
  formVersion    String            @default("1.0.0")
  reviewedById   String?
  submittedAt    DateTime?
  patient        Patient           @relation(fields: [patientId], references: [id])
  subscription   Subscription?     @relation(fields: [subscriptionId], references: [id])
  reviewedBy     ProfessionalProfile? @relation(fields: [reviewedById], references: [id])

  @@index([patientId, vertical])
}

model Prescription {
  id             String             @id @default(uuid())
  patientId      String
  doctorId       String
  subscriptionId String
  drugName       String
  doseMg         Decimal
  frequency      String
  quantity       Int
  status         PrescriptionStatus @default(ACTIVE)
  issuedAt       DateTime           @default(now())
  expiresAt      DateTime
  digitalSig     String
  patient        Patient            @relation(fields: [patientId], references: [id])
  doctor         ProfessionalProfile @relation(fields: [doctorId], references: [id])
  subscription   Subscription       @relation(fields: [subscriptionId], references: [id])
  orders         Order[]

  @@index([patientId, status])
}

model Order {
  id               String            @id @default(uuid())
  patientId        String
  prescriptionId   String
  subscriptionId   String
  pharmacyId       String
  status           OrderStatus       @default(PENDING)
  deliveryAddrEnc  String
  logisticsPartner LogisticsPartner?
  trackingNumber   String?
  createdAt        DateTime          @default(now())
  deliveredAt      DateTime?
  patient          Patient           @relation(fields: [patientId], references: [id])
  prescription     Prescription      @relation(fields: [prescriptionId], references: [id])
  subscription     Subscription      @relation(fields: [subscriptionId], references: [id])
  pharmacy         Pharmacy          @relation(fields: [pharmacyId], references: [id])

  @@index([pharmacyId, status])
}

model TreatmentPlan {
  id             String              @id @default(uuid())
  patientId      String
  professionalId String
  title          String
  description    String?
  status         TreatmentPlanStatus @default(ACTIVE)
  startDate      DateTime            @default(now())
  endDate        DateTime?
  patient        Patient             @relation(fields: [patientId], references: [id])
  professional   ProfessionalProfile @relation(fields: [professionalId], references: [id])

  @@index([patientId])
}

// --- Lab Diagnostics ---

model LabTestRequest {
  id             String           @id @default(uuid())
  patientId      String
  professionalId String
  testCodes      String // JSON array of codes
  status         LabRequestStatus @default(PENDING)
  sampleMethod   SampleMethod     @default(WALK_IN)
  requestedAt    DateTime         @default(now())
  patient        Patient          @relation(fields: [patientId], references: [id])
  professional   ProfessionalProfile @relation(fields: [professionalId], references: [id])
  results        LabResult[]

  @@index([patientId, status])
}

model LabResult {
  id             String         @id @default(uuid())
  requestId      String
  testName       String
  value          String
  unit           String?
  referenceRange String?
  flag           ResultFlag     @default(NORMAL)
  labNotes       String?
  recordedAt     DateTime       @default(now())
  request        LabTestRequest @relation(fields: [requestId], references: [id])

  @@index([requestId])
}

// --- Nutrition ---

model DietPlan {
  id             String         @id @default(uuid())
  patientId      String
  professionalId String
  status         DietPlanStatus @default(ACTIVE)
  caloriesPerDay Int?
  macroSplit     String? // JSON: {p:30, c:40, f:30}
  instructions   String?
  startDate      DateTime       @default(now())
  endDate        DateTime?
  patient        Patient        @relation(fields: [patientId], references: [id])
  professional   ProfessionalProfile @relation(fields: [professionalId], references: [id])
  adherenceLogs  DietAdherenceLog[]

  @@index([patientId])
}

model DietAdherenceLog {
  id         String   @id @default(uuid())
  planId     String
  date       DateTime @db.Date
  adhered    Boolean
  userNotes  String?
  plan       DietPlan @relation(fields: [planId], references: [id])

  @@index([planId, date])
}

// --- Communication & Interaction ---

model Message {
  id         String        @id @default(uuid())
  patientId  String
  senderId   String
  threadType MessageThread
  contentEnc String
  isRead     Boolean       @default(false)
  createdAt  DateTime      @default(now())
  patient    Patient       @relation(fields: [patientId], references: [id])

  @@index([patientId, createdAt])
}

model ConsultationNote {
  id             String          @id @default(uuid())
  patientId      String
  professionalId String
  type           ConsultNoteType @default(SOAP)
  contentEnc     String // Encrypted SOAP or follow-up notes
  createdAt      DateTime        @default(now())
  patient        Patient         @relation(fields: [patientId], references: [id])
  professional   ProfessionalProfile @relation(fields: [professionalId], references: [id])
  videoSlot      VideoSlot?

  @@index([patientId, createdAt])
}

model VideoSlot {
  id             String            @id @default(uuid())
  professionalId String
  patientId      String?
  startTime      DateTime
  endTime        DateTime
  isBooked       Boolean           @default(false)
  consultationNoteId String?       @unique
  professional   ProfessionalProfile @relation(fields: [professionalId], references: [id])
  consultationNote   ConsultationNote? @relation(fields: [consultationNoteId], references: [id])

  @@index([professionalId, startTime])
}

// --- Monitoring & Audit ---

model ProgressEntry {
  id                  String   @id @default(uuid())
  patientId           String
  weightKg            Decimal
  notes               String?
  dietitianAnnotation String?
  enteredById         String // User ID of person who entered it
  recordedAt          DateTime @default(now())
  patient             Patient  @relation(fields: [patientId], references: [id])
  enteredBy           ProfessionalProfile @relation(fields: [enteredById], references: [id])

  @@index([patientId, recordedAt])
}

model PaymentEvent {
  id             String       @id @default(uuid())
  subscriptionId String
  paystackRef    String       @unique
  event          String
  amount         Int
  payload        String
  processedAt    DateTime     @default(now())
  subscription   Subscription @relation(fields: [subscriptionId], references: [id])

  @@index([subscriptionId])
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  action     String
  entityType String?
  entityId   String?
  ipAddress  String?
  userAgent  String?
  metadata   String?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([entityType, entityId])
}
